@model WebBanDienThoai.Models.ForgotPasswordViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Forgot Password";
}

<style>
    body, html { background: #f5f5f7 !important; color: #1d1d1f; }
    .ui-main { background: #f5f5f7; }
    .account-shell { max-width: 560px; margin: 0 auto; }
    .account-title { font-size: 44px; line-height: 1.05; font-weight: 800; margin: 0 0 12px; }
    .account-copy { color: #6e6e73; margin: 0 0 28px; }
    .account-card { background: #fff; border: 1px solid #e8e8ed; border-radius: 8px; padding: 28px; box-shadow: 0 18px 38px rgba(0,0,0,.05); }
    .account-label { display: block; color: #6e6e73; font-size: 13px; font-weight: 700; margin: 16px 0 8px; }
    .account-input { width: 100%; box-sizing: border-box; background: #fbfbfd; border: 1px solid #d2d2d7; border-radius: 8px; color: #1d1d1f; padding: 13px 14px; outline: none; }
    .account-input:focus { border-color: #0071e3; box-shadow: 0 0 0 3px rgba(0,113,227,.14); }
    .account-btn { width: 100%; border: 0; border-radius: 999px; padding: 13px 18px; font-weight: 800; background: #0071e3; color: #fff; margin-top: 22px; }
    .account-links { margin-top: 18px; }
    .account-links a { color: #06c; text-decoration: none; font-weight: 600; font-size: 14px; }
    .validation-summary-errors { background: #fff2f2; border: 1px solid #ffd7d7; color: #b42318; border-radius: 8px; padding: 12px 14px; margin-bottom: 18px; font-weight: 700; }
    .validation-summary-errors ul { margin: 0; padding-left: 18px; }
</style>

<section class="account-shell">
    <h1 class="account-title">Reset your password.</h1>
    <p class="account-copy">Confirm your username and phone number, then set a new password.</p>

    <div class="account-card">
        @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true)

            <label class="account-label">Username</label>
            @Html.TextBoxFor(m => m.Username, new { @class = "account-input", required = "required" })

            <label class="account-label">Phone number</label>
            @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "account-input", required = "required" })

            <label class="account-label">New password</label>
            @Html.PasswordFor(m => m.NewPassword, new { @class = "account-input", required = "required" })

            <label class="account-label">Confirm new password</label>
            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "account-input", required = "required" })

            <button type="submit" class="account-btn">Update Password</button>
        }

        <div class="account-links">
            <a href="@Url.Action("Login", "Account")">Back to sign in</a>
        </div>
    </div>
</section>
